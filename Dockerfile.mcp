# Fitter MCP server image (slim: server/static/file connectors; no browsers).
#
# stdio mode (default, for MCP clients that spawn containers):
#   docker run --rm -i ghcr.io/pxyup/fitter-mcp:latest
#
# hosted HTTP mode:
#   docker run --rm -p 8080:8080 \
#     -e FITTER_MCP_HTTP_ADDR=:8080 \
#     -e FITTER_MCP_AUTH_TOKEN=my-secret \
#     ghcr.io/pxyup/fitter-mcp:latest

FROM --platform=$BUILDPLATFORM golang:1.25-alpine AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG TARGETOS
ARG TARGETARCH
ARG VERSION=dev
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -ldflags="-X main.version=${VERSION#v}" -o /out/fitter_mcp ./cmd/mcp

FROM alpine:3.20

LABEL org.opencontainers.image.source="https://github.com/PxyUp/fitter" \
      org.opencontainers.image.description="Fitter MCP server — web data for AI agents" \
      org.opencontainers.image.licenses="MIT" \
      io.modelcontextprotocol.server.name="io.github.PxyUp/fitter"

RUN apk add --no-cache ca-certificates

COPY --from=build /out/fitter_mcp /usr/local/bin/fitter_mcp

USER nobody:nobody

EXPOSE 8080

# healthy in HTTP mode when /healthz answers; a no-op in stdio mode
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s \
  CMD [ -z "$FITTER_MCP_HTTP_ADDR" ] || wget -qO- "http://127.0.0.1:${FITTER_MCP_HTTP_ADDR##*:}/healthz" || exit 1

ENTRYPOINT ["fitter_mcp"]
